# ===================================
# LLM Configuration (OpenRouter)
# ===================================
# OpenRouter API Key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Model name (any model available on OpenRouter)
# Examples: google/gemini-2.0-flash-001, anthropic/claude-sonnet-4-20250514, openai/gpt-4o
LLM_MODEL=google/gemini-2.0-flash-001

# ===================================
# Vietnam Stock Market APIs
# ===================================
# TCBS API Base URL (default: https://apipubaws.tcbs.com.vn)
TCBS_API_BASE_URL=https://apipubaws.tcbs.com.vn

# SSI API Credentials (if you have SSI account)
SSI_API_KEY=your_ssi_api_key_here
SSI_API_SECRET=your_ssi_api_secret_here

# ===================================
# Application Settings
# ===================================
# Debug mode: true/false
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
